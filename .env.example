# This is just an example file for our env file. It has not secrets
# and therefore, can be pushed to the remote branch

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TRANSACTIONS_TOPIC=transactions
KAFKA_ALERTS_TOPIC=fraud_alerts
KAFKA_CONSUMER_GROUP=transaction-monitor-group

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=transaction_monitoring
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# App
APP_ENV=local
LOG_LEVEL=INFO

# Fraud rules
HIGH_AMOUNT_THRESHOLD=10000
VELOCITY_WINDOW_SECONDS=60
VELOCITY_TRANSACTION_COUNT=5
COUNTRY_JUMP_WINDOW_SECONDS=300